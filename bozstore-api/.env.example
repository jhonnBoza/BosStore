# ── Servidor ──────────────────────────────────────────────
PORT=4000
NODE_ENV=development
FRONTEND_URL=http://localhost:3000

# ── Supabase ──────────────────────────────────────────────
SUPABASE_URL=https://<project>.supabase.co

# Clave de servicio — SECRETO, solo backend, NUNCA al cliente
SUPABASE_SERVICE_ROLE_KEY=

# Endpoint de claves públicas para verificar el JWT (RS256)
SUPABASE_JWKS_URL=https://<project>.supabase.co/auth/v1/.well-known/jwks.json

# ── Pagos (Stripe) ────────────────────────────────────────
# Opcionales: el servidor arranca sin ellas; los pagos se activan al rellenarlas.
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=

# ── Correo (SMTP) para los códigos de verificación ────────
# Opcionales: el envío de correos se activa al rellenar SMTP_USER y SMTP_PASS.
# Para Gmail: usa una "Contraseña de aplicación" (no tu contraseña normal).
SMTP_HOST=smtp.gmail.com
SMTP_PORT=465
SMTP_USER=
SMTP_PASS=
SMTP_FROM=
