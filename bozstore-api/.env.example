# ── Servidor ──────────────────────────────────────────────
PORT=4000
NODE_ENV=development
FRONTEND_URL=http://localhost:3000

# ── Supabase ──────────────────────────────────────────────
SUPABASE_URL=https://<project>.supabase.co

# Clave de servicio — SECRETO, solo backend, NUNCA al cliente
SUPABASE_SERVICE_ROLE_KEY=

# Endpoint de claves públicas para verificar el JWT (RS256)
SUPABASE_JWKS_URL=https://<project>.supabase.co/auth/v1/.well-known/jwks.json

# ── Pagos (Stripe) ────────────────────────────────────────
# Opcionales: el servidor arranca sin ellas; los pagos se activan al rellenarlas.
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=

# ── Correo — Brevo (API HTTPS), para producción ───────────
# Recomendado en hosts que bloquean SMTP saliente (ej. Render free).
# Se genera en Brevo → Settings → SMTP & API → API Keys.
# BREVO_SENDER_EMAIL debe ser un remitente verificado en Brevo.
# Si se rellena, tiene prioridad sobre SMTP_* de abajo.
BREVO_API_KEY=
BREVO_SENDER_EMAIL=

# ── Correo (SMTP) para los códigos de verificación ────────
# Alternativa para desarrollo LOCAL (muchos hosts en la nube bloquean SMTP).
# Opcionales: el envío de correos se activa al rellenar SMTP_USER y SMTP_PASS.
# Para Gmail: usa una "Contraseña de aplicación" (no tu contraseña normal).
SMTP_HOST=smtp.gmail.com
SMTP_PORT=465
SMTP_USER=
SMTP_PASS=
SMTP_FROM=
