NEXT_PUBLIC_SUPABASE_ANON_KEY=

# URL de la API de Express
NEXT_PUBLIC_API_URL=http://localhost:4000/api/v1

# Video de fondo del hero (opcional — si está vacío se muestra imagen estática)
NEXT_PUBLIC_HERO_VIDEO_URL=
